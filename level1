<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>JavaQuest Level 1 - Variables</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      background: #f4f9ff;
      margin: 0;
      padding: 30px;
      text-align: center;
    }
    h1 { margin-bottom: 10px; }
    .task {
      background: white;
      padding: 20px;
      border-radius: 10px;
      max-width: 800px;
      margin: 20px auto;
      box-shadow: 0 8px 16px rgba(0,0,0,0.1);
      text-align: left;
    }
    textarea {
      width: 100%;
      height: 180px;
      margin-top: 15px;
      font-family: monospace;
      font-size: 14px;
      padding: 10px;
    }
    button {
      margin-top: 15px;
      padding: 10px 20px;
      font-size: 16px;
      cursor: pointer;
      border-radius: 6px;
      border: none;
    }
    #result {
      margin-top: 15px;
      font-weight: bold;
      font-size: 18px;
    }
    .back {
      margin-top: 20px;
      display: inline-block;
      text-decoration: none;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <h1>Level 1: Variables</h1>

  <div class="task">
    <p><strong>Task:</strong> Create an integer variable named <code>age</code> and assign it the value <code>16</code>.</p>
    <p>Example format:</p>
    <pre>int number = 5;</pre>

    <textarea id="code" placeholder="Type your Java code here..."></textarea>
    <button onclick="checkCode()">Run Code</button>

    <div id="result"></div>
  </div>

  <a class="back" href="index.html">⬅ Back to Levels</a>

  <script>
    function normalize(text) {
      return text.replace(/\s+/g, '').toLowerCase();
    }

    function checkCode() {
      const userCode = normalize(document.getElementById("code").value);

      const acceptedPatterns = [
        "intage=16;",
        "intage=16"
      ];

      const isCorrect = acceptedPatterns.some(p => userCode.includes(p));

      if (isCorrect) {
        document.getElementById("result").innerText = "✅ Correct! You earned 10 XP.";
      } else if (userCode.includes("int") && userCode.includes("age")) {
        document.getElementById("result").innerText = "🟡 Almost! Check the value and syntax. It should be 16.";
      } else {
        document.getElementById("result").innerText = "❌ Not quite. Make sure you declared: int age = 16;";
      }
    }
  </script>
</body>
</html>
